# ====================================
# API Configuration
# ====================================
# Point this to your backend Express server
VITE_API_URL=http://localhost:5000/api

# ====================================
# Microsoft Authentication (MSAL)
# ====================================
# The Client ID of your Azure AD App Registration
VITE_AZURE_CLIENT_ID=your_azure_client_id_here

# The Tenant ID (or 'common' for multi-tenant)
VITE_AZURE_TENANT_ID=your_azure_tenant_id_here
